<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <!-- Connexion à la base -->
        <property name="hibernate.connection.driver_class">com.mysql.cj.jdbc.Driver</property>
        <property name="hibernate.connection.url">jdbc:mysql://localhost:3306/ma_base</property>
        <property name="hibernate.connection.username">root</property>
        <property name="hibernate.connection.password">root</property>

        <!-- Dialect -->
        <property name="hibernate.dialect">org.hibernate.dialect.MySQLDialect</property>

        <!-- Génération automatique -->
        <property name="hibernate.hbm2ddl.auto">create</property>

        <!-- Affichage SQL -->
        <property name="hibernate.show_sql">true</property>

        <!-- Classes entités -->
        <mapping class="ma.projet.classes.Produit"/>
        <mapping class="ma.projet.classes.Commande"/>
        <mapping class="ma.projet.classes.LigneCommande"/>
    </session-factory>
</hibernate-configuration>